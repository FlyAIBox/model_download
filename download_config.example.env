# Copy to download_config.env and fill only the values you need.
# Prefer access tokens. Do not store real passwords here unless your local
# security policy allows plaintext secrets in this working directory.

# Hugging Face private or gated repos:
# https://huggingface.co/settings/tokens
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=

# ModelScope private or gated repos:
# Use the token/key provided by your ModelScope account settings.
MODELSCOPE_TOKEN=
MODELSCOPE_API_TOKEN=
MODELSCOPE_ACCESS_TOKEN=

# Optional metadata placeholders. The downloader does not submit passwords.
HF_USERNAME=
HF_PASSWORD=
MODELSCOPE_USERNAME=
MODELSCOPE_PASSWORD=
